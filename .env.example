# Copy to .env and fill in locally. .env is gitignored.
#
# Push crawler export to offerTrackPlatform (offertrack-push binary reads these too):
# OFFERTRACK_API_URL=http://localhost:3000
# OFFERTRACK_ADMIN_KEY=            # required if platform sets ADMIN_API_KEY
#
# Examples for future ML / API integration (not all are used by this repo yet):
# OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
